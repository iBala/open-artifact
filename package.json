{
  "name": "open-artifact-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Open source artifact manager: publish HTML and Markdown from LLM harnesses, share and comment on them.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @open-artifact/shared build && pnpm --filter @open-artifact/web build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
