# Open Artifact configuration.
# Copy to .env next to your docker-compose file and fill in the required values.
# The server validates all of this at boot and refuses to start with a clear
# message if anything is missing or wrong, so a typo never becomes a runtime bug.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# The public address of this instance. No trailing slash. Every link the server
# sends (sign-in emails, share notifications, artifact URLs) is built from this.
BASE_URL=https://artifacts.example.com

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
# At least 32 characters. Changing it signs everyone out.
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Required in production only
# ---------------------------------------------------------------------------

# Mail server used for sign-in links and share notifications. Without it nobody
# can log in, so production will not start unless SMTP_HOST is set.
# For Amazon SES, use the SMTP endpoint of your region.
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Set to true only if your server uses implicit TLS on a port other than 465.
SMTP_SECURE=false
# The address emails are sent from. Must be verified with your mail provider.
MAIL_FROM=Open Artifact <no-reply@example.com>

# ---------------------------------------------------------------------------
# Optional, with defaults
# ---------------------------------------------------------------------------

# development | test | production. Default: development
NODE_ENV=production

# Port the server listens on. Default: 3000
PORT=3000

# Where the SQLite database file lives. Back this file up and you have
# backed up everything. Default: ./data/open-artifact.db
DATABASE_PATH=/data/open-artifact.db

# debug | info | warn | error. Default: info
LOG_LEVEL=info

# Largest artifact file accepted, in bytes. Default: 5242880 (5 MB)
MAX_ARTIFACT_BYTES=5242880

# New shares per hour, per person. Sharing emails an address the sharer chose,
# so without a limit anyone with an account can use this instance to send mail.
# Default: 30
MAX_SHARES_PER_HOUR=30

# Who is allowed to create an account on this instance. Default: invite-only
#   open             anyone with an email address can sign up
#   invite-only      only people who have been shared an artifact can sign up
#   domain-allowlist only the email domains listed below can sign up
SIGNUP_MODE=invite-only

# Comma separated. Required when SIGNUP_MODE is domain-allowlist.
SIGNUP_ALLOWED_DOMAINS=example.com,zorp.one

# ---------------------------------------------------------------------------
# Optional: Google sign-in
# ---------------------------------------------------------------------------
# Leave both blank to offer sign-in by email link only. Set both to add a
# "Continue with Google" button. Setting only one is an error, so a half-finished
# setup fails loudly instead of quietly disabling the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
